Bootstrap: docker
From: condaforge/miniforge3:latest

%post
    # Install system packages
    apt-get update && apt-get install -y git build-essential
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install onto-vae package from GitHub (provides onto_vae Python package)
    git clone https://github.com/willsketch/onto-vae.git /opt/onto-vae

    # Create conda environment and install dependencies
    conda create -n ontovae python=3.9 -y
    conda run -n ontovae pip install -U pip setuptools
    conda run -n ontovae pip install -e /opt/onto-vae
    conda run -n ontovae pip install pyarrow

    # Clean up
    mamba clean --all -y

    # Activate ontovae environment on container start
    echo '. "/opt/conda/etc/profile.d/conda.sh"' >> $APPTAINER_ENVIRONMENT
    echo 'conda activate ontovae' >> $APPTAINER_ENVIRONMENT

%runscript
    # /workspace is bound to the cluster project directory at runtime:
    #   apptainer run --nv -B /cluster/path/onto-vae:/workspace image.sif [args]
    cd /workspace
    exec python OntoVAE-Runs.py "$@"
